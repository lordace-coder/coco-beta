# =============================================================
# Cocobase - Self-Hosted Configuration
# Copy this file to .env and fill in your values
# =============================================================

# -------------------------
# Server
# -------------------------
PORT=3000
ENVIRONMENT=development   # development | production
API_VERSION=v1

# -------------------------
# Database (required)
# -------------------------
DATABASE_URL=postgres://user:password@localhost:5432/cocobase

# -------------------------
# Security (required)
# -------------------------
# Change this to a long random string in production
SECRET=change-me-in-production

# -------------------------
# File Storage (optional)
# S3-compatible storage via Backblaze B2
# Leave empty to disable file upload features
# -------------------------
BACKBLAZE_KEY_ID=
BACKBLAZE_KEY_NAME=
BACKBLAZE_APPLICATION_KEY=
BUCKET_NAME=
BUCKET_ENDPOINT=

# -------------------------
# Redis (optional)
# Required for realtime features (subscriptions, broadcasts)
# Leave empty to disable realtime
# -------------------------
REDIS_URL=redis://localhost:6379

# -------------------------
# Frontend URL
# Used for CORS and redirect links
# -------------------------
FRONTEND_URL=http://localhost:3000

# -------------------------
# Mailer (optional)
# Required for email features (verification, password reset)
# -------------------------
MAILER_API_KEY=
MAILER_URL=

# -------------------------
# OAuth Providers (optional)
# Only configure the providers you want to support
# -------------------------

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# -------------------------
# Admin Dashboard
# Credentials for the built-in admin UI
# -------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# -------------------------
# Rate Limiting (optional)
# Set RATE_LIMIT_REQUESTS to 0 to disable rate limiting
# -------------------------
RATE_LIMIT_REQUESTS=0       # max requests per window (0 = unlimited)
RATE_LIMIT_WINDOW=60        # window size in seconds

# -------------------------
# SMTP (optional but recommended)
# Used for password reset, email verification, welcome emails
# Configure here OR via the admin dashboard (dashboard config takes priority)
# -------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@gmail.com
SMTP_FROM_NAME=My App
SMTP_SECURE=false   # true = SSL on port 465, false = STARTTLS on port 587
