# flyctl launch added from .gitignore
# Binaries for programs and plugins
**/*.exe
**/*.exe~
**/*.dll
**/*.so
**/*.dylib

# Test binary, built with `go test -c`
**/*.test

# Output of the go coverage tool
**/*.out

# Dependency directories
**/vendor

# Go workspace file
**/go.work

# Environment variables
**/.env

# IDE specific files
**/.vscode
**/.idea
**/*.swp
**/*.swo
**/*~

# OS specific files
**/.DS_Store
**/Thumbs.db

# Build output
**/bin
**/build
# Exclude dashboard source dist but keep embedded dist
dashboard/dist
# Keep internal/dashboardfs/dist — it's embedded into the binary
!internal/dashboardfs/dist

# Log files
**/*.log

# Temporary files
**/tmp
**/temp
fly.toml
